# .env.example — Merchant Dashboard
# Copy to .env.local and fill in your real values. Never commit .env.local to version control.

# ─── API ──────────────────────────────────────────────────────────────────────
# The URL of your deployed Payment API.
# Local dev: http://localhost:3001
# Production: https://your-payment-api.railway.app (or equivalent)
NEXT_PUBLIC_API_URL="https://global-remittance-api.onrender.com"

# ─── Stellar / Soroban ────────────────────────────────────────────────────────
# Network selection: "testnet" or "mainnet"
NEXT_PUBLIC_NETWORK="testnet"

# The deployed Soroban escrow contract ID (56-char C-address).
NEXT_PUBLIC_CONTRACT_ID="CBL3I4IDMIUZJEJG56DV2VP6K7L2ROLT3JYCC53KNU7PPUX6DGPJJVKC"
