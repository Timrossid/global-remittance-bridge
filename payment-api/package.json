{
  "name": "payment-api",
  "version": "0.1.0",
  "description": "Backend API for Global Micro-Remittance Bridge",
  "author": "opencode",
  "private": true,
  "scripts": {
    "build": "npx nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "npx nest start",
    "start:dev": "npx nest start --watch",
    "start:prod": "sh deploy.sh",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r jest node_modules/.bin/jest --runInBand",
    "postinstall": "patch-package"
  },
  "dependencies": {
    "@nestjs/axios": "^4.0.1",
    "@nestjs/common": "^10.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/jwt": "^10.0.0",
    "@nestjs/passport": "^10.0.0",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/cli": "^10.0.0",
    "@nestjs/schematics": "^10.0.0",
    "@noble/hashes": "2.2.0",
    "@prisma/client": "^5.0.0",
    "@stellar/stellar-sdk": "^16.0.1",
    "axios": "^1.18.1",
    "bullmq": "^4.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "passport": "^0.6.0",
    "passport-jwt": "^4.0.0",
    "patch-package": "^8.0.1",
    "prisma": "^5.0.0",
    "redis": "^4.6.0",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.0",
    "soroban-client": "^1.0.1",
    "ts-node": "^10.9.1",
    "typescript": "^5.1.0"
  },
  "devDependencies": {
    "@nestjs/testing": "^10.0.0",
    "@types/express": "^4.17.17",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^7.2.0",
    "jest": "^29.5.0",
    "prettier": "^3.0.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.1.0",
    "ts-loader": "^9.4.0"
  },
  "overrides": {
    "@noble/ed25519": "1.3.0"
  },
  "resolutions": {
    "@noble/ed25519": "1.3.0"
  }
}
