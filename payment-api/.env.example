# .env.example — Payment API
# Copy to .env and fill in your real values. Never commit .env to version control.
# For security: database passwords, API keys, and keypairs should be stored in your deployment platform's secrets manager.

# ─── Database (PostgreSQL with Connection Pooling) ──────────────────────────
# Render.com example: https://dashboard.render.com
# For production: Use connection pooler (port 6543) for app, direct connection (5432) for migrations
DATABASE_URL="postgresql://username:your_secure_password@db-hostname.render.com:6543/dbname?pgbouncer=true"
DIRECT_URL="postgresql://username:your_secure_password@db-hostname.render.com:5432/dbname"

# ─── Authentication ───────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Must be at least 32 characters and kept secret
JWT_SECRET="your_generated_32_char_hex_string_here"

# ─── Stellar Network ─────────────────────────────────────────────────────────
STELLAR_NETWORK="testnet"

# Stellar keypair for signing settlement transactions
# Generate at: https://laboratory.stellar.org/#account-creator or with stellar-cli
# Never commit real keys to version control; use platform secrets
STELLAR_SECRET="SXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"
STELLAR_PUBLIC_KEY="GXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"

# Soroban RPC endpoint for the selected network.
# Testnet: https://soroban-testnet.stellar.org
# Mainnet: https://soroban-rpc.stellar.org (or a third-party provider)
SOROBAN_RPC_URL="https://soroban-testnet.stellar.org"

# The deployed Soroban contract addresses (56-char C-addresses).
# Get from deployment logs or https://stellar.expert/explorer/testnet
SOROBAN_CONTRACT_ID="CBL3I4IDMIUZJEJG56DV2VP6K7L2ROLT3JYCC53KNU7PPUX6DGPJJVKC"
SETTLEMENT_CONTRACT_ID="CBBH6JHHNKAC4E444EIYG3HGNPYLVFLY72OMRYCCLFZU4ASVU3AO73QR"
# Deploy with: stellar contract deploy --wasm contracts/escrow/target/...
SOROBAN_CONTRACT_ID="CBL3I4IDMIUZJEJG56DV2VP6K7L2ROLT3JYCC53KNU7PPUX6DGPJJVKC"

# ─── Infrastructure ───────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── Integrations ─────────────────────────────────────────────────────────────
ANCHOR_API_URL="https://api.anchor-provider.com"

# Base URL for merchant webhooks (optional, for status update notifications)
WEBHOOK_BASE_URL="https://your-merchant-domain.com"
