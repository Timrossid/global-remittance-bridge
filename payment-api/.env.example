# .env.example — Payment API
# Copy to .env and fill in your real values. Never commit .env to version control.

# ─── Database (Supabase / PostgreSQL) ────────────────────────────────────────
# Use the shared transaction-mode pooler (port 6543) for the application.
DATABASE_URL="postgresql://<DB_USER>:<DB_PASSWORD>@<DB_HOST>:6543/<DB_NAME>?pgbouncer=true"

# Use the direct connection (port 5432) for Prisma migrations.
DIRECT_URL="postgresql://<DB_USER>:<DB_PASSWORD>@<DB_HOST>:5432/<DB_NAME>"

# ─── Authentication ───────────────────────────────────────────────────────────
# Generate a strong secret: openssl rand -hex 32
JWT_SECRET="<your_jwt_secret_min_32_chars>"

# ─── Stellar Network ─────────────────────────────────────────────────────────
STELLAR_NETWORK="testnet"

# Server-side Stellar keypair used for signing settlement transactions.
# Generate one at: https://laboratory.stellar.org/#account-creator
STELLAR_SECRET="<your_stellar_secret_key_S...>"
STELLAR_PUBLIC_KEY="<your_stellar_public_key_G...>"

# Soroban RPC endpoint for the selected network.
# Testnet: https://soroban-testnet.stellar.org
# Mainnet: https://soroban-rpc.stellar.org (or a third-party provider)
SOROBAN_RPC_URL="https://soroban-testnet.stellar.org"

# The deployed Soroban escrow contract address (56-char C-address).
# Deploy with: stellar contract deploy --wasm contracts/escrow/target/...
SOROBAN_CONTRACT_ID="CBL3I4IDMIUZJEJG56DV2VP6K7L2ROLT3JYCC53KNU7PPUX6DGPJJVKC"

# ─── Infrastructure ───────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── Integrations ─────────────────────────────────────────────────────────────
ANCHOR_API_URL="https://api.anchor-provider.com"

# Base URL for merchant webhooks (optional, for status update notifications)
WEBHOOK_BASE_URL="https://your-merchant-domain.com"
